# SmartRecruit Backend - Configuration

# Environnement
NODE_ENV=development
PORT=5000

# MongoDB
# Pour MongoDB local:
MONGO_URI=mongodb://localhost:27017/smartrecruit

# Pour MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/smartrecruit?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=smartrecruit_secret_key_2026_change_this_in_production
JWT_EXPIRE=7d
JWT_EXPIRE_ADMIN=1d

# Email Configuration (SMTP)
# Pour Gmail:
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre_email@gmail.com
EMAIL_PASS=votre_mot_de_passe_app_gmail
EMAIL_FROM=noreply@smartrecruit.tn

# Pour Outlook:
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587

# Pour SendGrid:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.jpg,.jpeg,.png,.mp4,.mov,.webm

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin Security
ADMIN_MAX_ATTEMPTS=3
ADMIN_LOCKOUT_TIME=300000

# Cache
CACHE_TTL=600
CACHE_CHECKPERIOD=120

# Pagination
DEFAULT_PAGE=1
DEFAULT_LIMIT=10
MAX_LIMIT=100

# Subscription Plans (en TND)
SUBSCRIPTION_BASIC_PRICE=50
SUBSCRIPTION_PRO_PRICE=150
SUBSCRIPTION_ENTERPRISE_PRICE=500

# Session
SESSION_SECRET=smartrecruit_session_secret_2026

# OAuth (Optionnel - pour intégrations futures)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Analytics (Optionnel)
GOOGLE_ANALYTICS_ID=

# Logs
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# CORS
CORS_ORIGIN=http://localhost:3000

# Upload Paths
UPLOAD_PATH=./uploads
CV_UPLOAD_PATH=./uploads/cvs
VIDEO_UPLOAD_PATH=./uploads/videos
PROFILE_UPLOAD_PATH=./uploads/profiles
